rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /settings/{document} {
      allow read: if true;
      allow write: if false;
      // NOTE: Settings writes happen from admin.js directly using the
      // Firebase client SDK. For production, add Firebase Authentication
      // and replace `if false` with `if request.auth != null` on write rules.
    }
  }
}
